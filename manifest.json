<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#000000">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Pricing">
<link rel="manifest" href="manifest.json">
<link rel="icon" type="image/png" sizes="192x192" href="icons/icon-192.png">
<link rel="icon" type="image/png" sizes="512x512" href="icons/icon-512.png">
<link rel="apple-touch-icon" href="icons/apple-touch-icon.png">
<title>Pricing Calculator</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #000000;
    --bg-elevated: #161616;
    --accent: #2BB3A3;
    --accent-dim: #1F8377;
    --text: #F4F5F7;
    --text-muted: #7E8593;
    --border: #353944;
    --danger: #E2664B;
    --razer-green: #00FF00;
  }

  * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

  html, body {
    margin: 0;
    padding: 0;
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    height: 100%;
    min-height: 100vh;
    min-height: 100dvh;
    width: 100%;
    overscroll-behavior: none;
  }

  .screen {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    padding: env(safe-area-inset-top, 24px) 20px calc(env(safe-area-inset-bottom, 20px) + 20px) 20px;
    max-width: 480px;
    margin: 0 auto;
  }

  header {
    padding: 28px 4px 20px 4px;
  }

  .brand-header {
    text-align: center;
    margin-bottom: 18px;
  }

  .brand-header .brand-name {
    font-family: 'Chakra Petch', -apple-system, sans-serif;
    font-size: 36px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--razer-green);
    text-shadow: 0 0 18px rgba(0, 255, 0, 0.35);
    margin: 0;
  }

  header h1 {
    font-size: 22px;
    font-weight: 700;
    margin: 0 0 2px 0;
    letter-spacing: -0.01em;
    text-align: center;
  }

  header p {
    margin: 0;
    color: var(--text-muted);
    font-size: 14px;
  }

  .field {
    margin-bottom: 18px;
  }

  .field label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 8px;
    text-align: center;
  }

  .price-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-elevated);
    border: 2px solid var(--razer-green);
    border-radius: 14px;
    padding: 0 14px;
    transition: border-color 0.15s ease;
  }

  .price-input-wrap:focus-within {
    border-color: var(--accent);
  }

  .price-input-wrap .currency {
    font-size: 18px;
    color: var(--text-muted);
    font-weight: 600;
    margin-right: 4px;
  }

  #priceInput, #auRrpInput {
    flex: 0 1 auto;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-size: 22px;
    font-weight: 700;
    padding: 16px 0;
    width: 100%;
    min-width: 0;
    text-align: center;
    -moz-appearance: textfield;
    font-family: inherit;
  }

  #priceInput::-webkit-outer-spin-button,
  #priceInput::-webkit-inner-spin-button,
  #auRrpInput::-webkit-outer-spin-button,
  #auRrpInput::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  #priceInput::placeholder, #auRrpInput::placeholder {
    color: var(--text-muted);
    font-weight: 700;
  }

  .select-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .select-wrap {
    position: relative;
    background: var(--bg-elevated);
    border: 2px solid var(--razer-green);
    border-radius: 14px;
    transition: border-color 0.15s ease;
  }

  .select-wrap:focus-within {
    border-color: var(--accent);
  }

  .select-wrap::after {
    content: "";
    position: absolute;
    right: 16px;
    top: 50%;
    width: 9px;
    height: 9px;
    border-right: 2px solid var(--text-muted);
    border-bottom: 2px solid var(--text-muted);
    transform: translateY(-65%) rotate(45deg);
    pointer-events: none;
  }

  select {
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-size: 19px;
    font-weight: 700;
    padding: 16px 36px 16px 16px;
    text-align: center;
    text-align-last: center;
    appearance: none;
    -webkit-appearance: none;
    font-family: inherit;
  }

  select option {
    background: var(--bg-elevated);
    color: var(--text);
  }

  .result-card {
    margin-top: 8px;
    background: linear-gradient(155deg, var(--accent-dim), #176159);
    border: 2px solid var(--razer-green);
    border-radius: 18px;
    padding: 22px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 8px 24px -8px rgba(43, 179, 163, 0.35);
  }

  .result-card .result-label {
    font-size: 13px;
    font-weight: 600;
    color: rgba(244, 245, 247, 0.75);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 6px;
  }

  .result-card .result-value {
    font-size: 44px;
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .result-card .result-sub {
    margin-top: 10px;
    font-size: 14px;
    color: rgba(244, 245, 247, 0.85);
  }

  .result-card.empty {
    background: var(--bg-elevated);
    border: 1px dashed var(--border);
    box-shadow: none;
  }

  .result-card.empty .result-value {
    color: var(--text-muted);
    font-size: 28px;
  }

  .reset-button {
    margin-top: 14px;
    width: 100%;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 14px;
    color: var(--text-muted);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.03em;
    padding: 14px 0;
    font-family: inherit;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .reset-button:active {
    border-color: var(--razer-green);
    color: var(--text);
  }

  .spacer { flex: 1; }

  footer {
    text-align: center;
    color: var(--text-muted);
    font-size: 12px;
    padding-top: 24px;
  }
</style>
</head>
<body>
<div class="screen">

  <header>
    <div class="brand-header">
      <p class="brand-name">RAZER</p>
    </div>
    <h1>Pricing Calculator</h1>
  </header>

  <div class="field">
    <div class="select-grid">
      <div>
        <label for="auRrpInput">AU RRP INC</label>
        <div class="price-input-wrap">
          <span class="currency">$</span>
          <input id="auRrpInput" type="text" inputmode="decimal" placeholder="0.00" value="0.95">
        </div>
      </div>
      <div>
        <label for="priceInput">Synnex USD Ex</label>
        <div class="price-input-wrap">
          <span class="currency">$</span>
          <input id="priceInput" type="number" inputmode="decimal" placeholder="0.00" step="0.01" min="0">
        </div>
      </div>
    </div>
  </div>

  <div class="field">
    <label for="customerSelect">Customer</label>
    <div class="select-wrap">
      <select id="customerSelect">
        <option value="custom">Custom</option>
        <option value="jbhifi">JB Hi-Fi</option>
        <option value="amazon">Amazon</option>
        <option value="harveynorman">Harvey Norman</option>
        <option value="ebgames">EB Games</option>
        <option value="itchannel">IT Channel</option>
      </select>
    </div>
  </div>

  <div class="field">
    <div class="select-grid">
      <div>
        <label for="offListSelect">Off List</label>
        <div class="select-wrap">
          <select id="offListSelect">
            <option value="0">0%</option>
            <option value="10">10%</option>
            <option value="15">15%</option>
            <option value="20">20%</option>
            <option value="25" selected>25%</option>
            <option value="28">28%</option>
          </select>
        </div>
      </div>
      <div>
        <label for="berSelect">BER</label>
        <div class="select-wrap">
          <select id="berSelect">
            <option value="0">0%</option>
            <option value="10" selected>10%</option>
            <option value="15">15%</option>
            <option value="17">17%</option>
          </select>
        </div>
      </div>
    </div>
  </div>

  <div class="result-card empty" id="resultCard">
    <div class="result-label">Disti Margin</div>
    <div class="result-value" id="resultValue">0.00%</div>
  </div>

  <button type="button" id="resetButton" class="reset-button">Reset</button>

  <div class="spacer"></div>

</div>

<script>
  const priceInput = document.getElementById('priceInput');
  const auRrpInput = document.getElementById('auRrpInput');
  const customerSelect = document.getElementById('customerSelect');
  const offListSelect = document.getElementById('offListSelect');
  const berSelect = document.getElementById('berSelect');
  const resultCard = document.getElementById('resultCard');
  const resultValue = document.getElementById('resultValue');
  const resetButton = document.getElementById('resetButton');

  const FOREX = 1.5;
  const GST_DIVISOR = 1.1;

  const CUSTOMER_RATES = {
    jbhifi: { offList: 25, ber: 10 },
    amazon: { offList: 15, ber: 15 },
    harveynorman: { offList: 20, ber: 17 },
    ebgames: { offList: 28, ber: 10 },
    itchannel: { offList: 20, ber: 0 }
  };

  function applyCustomerRates() {
    const customer = customerSelect.value;
    const rates = CUSTOMER_RATES[customer];
    if (rates) {
      offListSelect.value = String(rates.offList);
      berSelect.value = String(rates.ber);
    }
    calculate();
  }

  function placeCursorBeforeCents() {
    const value = auRrpInput.value;
    const dotIndex = value.indexOf('.');
    const pos = dotIndex === -1 ? value.length : dotIndex;
    auRrpInput.setSelectionRange(pos, pos);
  }

  auRrpInput.addEventListener('focus', function () {
    setTimeout(placeCursorBeforeCents, 0);
  });

  auRrpInput.addEventListener('click', placeCursorBeforeCents);

  auRrpInput.addEventListener('keydown', function (e) {
    const value = auRrpInput.value;
    const dotIndex = value.indexOf('.');

    if (e.key >= '0' && e.key <= '9') {
      e.preventDefault();
      const dollarsPart = dotIndex === -1 ? value : value.slice(0, dotIndex);
      const centsPart = dotIndex === -1 ? '95' : value.slice(dotIndex + 1);
      const newDollars = (dollarsPart + e.key).replace(/^0+(?=\d)/, '');
      auRrpInput.value = newDollars + '.' + centsPart;
      placeCursorBeforeCents();
      calculate();
    } else if (e.key === 'Backspace') {
      e.preventDefault();
      const dollarsPart = dotIndex === -1 ? value : value.slice(0, dotIndex);
      const centsPart = dotIndex === -1 ? '95' : value.slice(dotIndex + 1);
      const newDollars = dollarsPart.slice(0, -1);
      auRrpInput.value = (newDollars === '' ? '0' : newDollars) + '.' + centsPart;
      placeCursorBeforeCents();
      calculate();
    } else if (e.key === 'Tab') {
      // allow normal tab navigation
    } else if (!['ArrowLeft', 'ArrowRight', 'ArrowUp', 'ArrowDown', 'Delete'].includes(e.key)) {
      e.preventDefault();
    }
  });

  auRrpInput.addEventListener('input', function () {
    const value = auRrpInput.value;
    const dotIndex = value.indexOf('.');
    const centsPart = dotIndex === -1 ? '' : value.slice(dotIndex + 1);
    if (centsPart !== '95') {
      const dollarsPart = (dotIndex === -1 ? value : value.slice(0, dotIndex)).replace(/\D/g, '');
      auRrpInput.value = (dollarsPart === '' ? '0' : dollarsPart) + '.95';
      placeCursorBeforeCents();
    }
  });

  function formatPercent(num) {
    return num.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + '%';
  }

  function calculate() {
    const synnexBuy = parseFloat(priceInput.value);
    const auRrp = parseFloat(auRrpInput.value);
    const offList = parseFloat(offListSelect.value) || 0;
    const ber = parseFloat(berSelect.value) || 0;

    if (isNaN(synnexBuy) || synnexBuy <= 0 || isNaN(auRrp) || auRrp <= 0) {
      resultCard.classList.add('empty');
      resultValue.textContent = '0.00%';
      return;
    }

    resultCard.classList.remove('empty');

    const synnexCost = synnexBuy * FOREX;
    const auRrpExGst = auRrp / GST_DIVISOR;
    const offListSellPrice = auRrpExGst * (1 - offList / 100);
    const berRebate = offListSellPrice * (ber / 100);
    const synnexNetRevenue = offListSellPrice - berRebate;
    const synnexMargin = synnexNetRevenue - synnexCost;
    const distiMargin = (synnexMargin / offListSellPrice) * 100;

    resultValue.textContent = formatPercent(distiMargin);
  }

  priceInput.addEventListener('input', calculate);
  auRrpInput.addEventListener('input', calculate);
  customerSelect.addEventListener('change', applyCustomerRates);
  offListSelect.addEventListener('change', function () {
    customerSelect.value = 'custom';
    calculate();
  });
  berSelect.addEventListener('change', function () {
    customerSelect.value = 'custom';
    calculate();
  });

  resetButton.addEventListener('click', function () {
    auRrpInput.value = '0.95';
    priceInput.value = '';
    customerSelect.value = 'custom';
    offListSelect.value = '25';
    berSelect.value = '10';
    calculate();
  });

  calculate();

  if ('serviceWorker' in navigator) {
    window.addEventListener('load', function () {
      navigator.serviceWorker.register('service-worker.js').catch(function (err) {
        console.warn('Service worker registration failed:', err);
      });
    });
  }
</script>

</body>
</html>
